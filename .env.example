# Qdrant REST API URL
QDRANT_URL=http://localhost:6333

# Ollama API URL
OLLAMA_URL=http://localhost:11434

# Embedding model — must be identical for ingest AND query
# nomic-embed-text produces 768-dimensional vectors
EMBEDDING_MODEL=nomic-embed-text

# Chat/generation model
CHAT_MODEL=llama3.2

# Shared collection name used by all repos
COLLECTION_NAME=codebase

# Vector dimension — must match your EMBEDDING_MODEL output
# nomic-embed-text = 768, mxbai-embed-large = 1024
VECTOR_SIZE=768

# Default top-K results returned by search
SEARCH_TOP_K=5

# Debounce in ms for the file watcher (batches rapid saves)
WATCH_DEBOUNCE_MS=1500
