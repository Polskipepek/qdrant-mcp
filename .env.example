# Qdrant REST API URL (used by MCP server)
QDRANT_URL=http://localhost:6333

# Ollama API URL (used by MCP server for embeddings and generation)
OLLAMA_URL=http://localhost:11434

# Ollama model used for embeddings (must match model used at ingest AND query time)
EMBEDDING_MODEL=nomic-embed-text

# Ollama model used for RAG answer generation
CHAT_MODEL=llama3.2

# Default number of search results returned by qdrant_search
SEARCH_TOP_K=5
